{
  "name": "approach-visualizer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=26.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:eslint": "eslint . --fix",
    "lint:stylelint": "stylelint \"src/**/*.{css,vue}\"",
    "lint:knip": "knip",
    "lint": "pnpm run lint:eslint && pnpm run lint:stylelint && pnpm run lint:oxlint && pnpm run lint:knip",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@sentry/vue": "^10.56.0",
    "@vueuse/core": "^14.3.0",
    "babylonjs": "9.5.0",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@vitejs/plugin-legacy": "^8.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-dom": "^3.5.35",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^10.4.1",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "knip": "^6.15.0",
    "npm-run-all2": "^9.0.1",
    "oxlint": "^1.68.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.3",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.48.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vite-plugin-csp-guard": "^4.0.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.3"
  },
  "packageManager": "pnpm@11.5.1"
}
