{
  "name": "approach-visualizer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint:oxlint": "oxlint -c oxlintrc.json src",
    "lint:eslint": "eslint . --fix",
    "lint:stylelint": "stylelint \"src/**/*.{css,vue}\"",
    "lint:knip": "knip",
    "lint": "yarn lint:eslint && yarn lint:stylelint && yarn lint:oxlint && yarn lint:knip",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@sentry/vue": "^10.45.0",
    "babylonjs": "^8.56.2",
    "normalize.css": "^8.0.1",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-legacy": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/compiler-dom": "^3.5.30",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "knip": "^6.0.5",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.57.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.46.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.2",
    "vite-plugin-csp-guard": "^3.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vitest": "^4.1.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "yarn@4.13.0"
}
