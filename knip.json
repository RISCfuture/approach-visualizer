{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "project": ["src/**/*.{ts,vue}"],
  "ignore": [
    "src/__tests__/**",
    "src/scene/runway/RunwayManager.ts",
    "src/scene/utils.ts",
    "src/scene/weather/WeatherEffects.ts"
  ],
  "ignoreDependencies": ["@vue/test-utils"],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "exports": "warn",
    "dependencies": "warn",
    "devDependencies": "warn",
    "binaries": "off",
    "unlisted": "off",
    "unresolved": "off"
  }
}
